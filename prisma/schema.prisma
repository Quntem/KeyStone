// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SERVICE
}

model User {
  id              String          @id @default(cuid())
  path            String          @default("/")
  email           String          @unique
  password        String
  role            Role            @default(USER)
  username        String
  name            String
  tenantId        String?
  tenant          tenant?         @relation(fields: [tenantId], references: [id])
  sessions        session[]
  managerId       String?
  manager         User?           @relation(fields: [managerId], references: [id], name: "managerUsers")
  managerUsers    User[]          @relation(name: "managerUsers")
  groups          groupUser[]
  userAppAccess   userAppAccess[]
  domainsCreator  domain[]        @relation(name: "DomainsCreator")
  disabled        Boolean         @default(false)
  domainId        String?
  domain          domain?         @relation(fields: [domainId], references: [id], name: "domainUsers")
  devices         Device[]
  enrolledDevices Device[]        @relation(name: "EnrolledDevices")
  departments     DepartmentUser[]
  locationId      String?
  location        location?       @relation(fields: [locationId], references: [id])
  orgRoles        OrgRoleUser[]
  extraInfo       Json?
  tags            String[]
  @@unique([tenantId, username])
}

enum TenantType {
  Organization
  Team
}

model tenant {
  displayName        String?
  id                 String              @id @default(cuid())
  name               String              @unique
  logo               String?
  color              String?
  description        String?
  colorContrast      String?
  users              User[]
  parentTenantId     String?
  parentTenant       tenant?             @relation(fields: [parentTenantId], references: [id], name: "tenantChildren")
  tenantChildren     tenant[]            @relation(name: "tenantChildren")
  apps               app[]
  domains            domain[]            @relation(name: "tenantDomains")
  groups             group[]
  externalAppAccess  ExternalAppAccess[]
  type               TenantType          @default(Organization)
  allowGroupCreation Boolean             @default(false)
  mdmServers         MdmServer[]
  devices            Device[]
  departments        department[]
  locations          location[]
}

model OrgRoleUser {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  orgRoleId String
  orgRole   OrgRole @relation(fields: [orgRoleId], references: [id])
}

model OrgRole {
  id    String  @id @default(cuid())
  name  String
  users OrgRoleUser[]
}

model group {
  id           String        @id @default(cuid())
  name         String
  description  String?
  groupname    String
  users        groupUser[]
  type         GroupType     @default(Organizational)
  tenantId     String
  tenant       tenant        @relation(fields: [tenantId], references: [id])
  domainId     String?
  domain       domain?       @relation(fields: [domainId], references: [id], name: "domainGroups")
  email        String?
  createdBy    String?
  adminCreated Boolean       @default(false)
  devices      DeviceGroup[]
  conditions   MagicGroupCondition[]
  includeAll   MagicGroupConditionTargetType?
  appAccess    GroupAppAccess[]

  @@unique([tenantId, groupname])
}

enum GroupType {
  Organizational
  Functional
  Magic
}

model MagicGroupCondition {
  id        String @id @default(cuid())
  groupId   String
  group     group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  targetType MagicGroupConditionTargetType
  attribute MagicGroupConditionAttributeType
  operator  MagicGroupConditionOperatorType
  value     String
}

enum MagicGroupConditionTargetType {
  User
  Device
  Both
}

enum MagicGroupConditionAttributeType {
  Email
  Departments
  Tags
  OrgRole
  Status
  Location
}

enum MagicGroupConditionOperatorType {
  Equals
  NotEquals
  Contains
  NotContains
  StartsWith
  EndsWith
  Includes
}

model DepartmentUser {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id])
  departmentId String
  department department @relation(fields: [departmentId], references: [id])
}

model department {
  id        String @id @default(cuid())
  name      String
  tenantId  String
  users     DepartmentUser[]
  tenant    tenant @relation(fields: [tenantId], references: [id])
}

model location {
  id        String @id @default(cuid())
  name      String
  tenantId  String
  users     User[]
  tenant    tenant @relation(fields: [tenantId], references: [id])
  devices   Device[]
}

model groupUser {
  id      String @id @default(cuid())
  userId  String
  groupId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model session {
  id          String           @id @default(cuid())
  userId      String
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id])
  expiresAt   DateTime         @default(dbgenerated("now() + interval '48 hours'"))
  appSessions userAppSession[]
}

model app {
  id                   String              @id @default(cuid())
  secret               String              @default(cuid())
  logo                 String
  description          String
  name                 String              @unique
  tenantId             String
  allowedURLs          String[]
  tenant               tenant              @relation(fields: [tenantId], references: [id])
  userAppAccess        userAppAccess[]
  groupAppAccess       GroupAppAccess[]
  mainUrl              String
  availableForExternal Boolean             @default(false)
  inExternalTenants    ExternalAppAccess[]
  publicExternal       Boolean             @default(false)
}

model ExternalAppAccess {
  id        String    @id @default(cuid())
  appId     String
  app       app       @relation(fields: [appId], references: [id])
  tenantId  String
  tenant    tenant    @relation(fields: [tenantId], references: [id])
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@unique([appId, tenantId])
}

model userAppAccess {
  id          String           @id @default(cuid())
  userId      String
  appId       String
  expiresAt   DateTime?
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id])
  app         app              @relation(fields: [appId], references: [id])
  appSessions userAppSession[]

  @@unique([userId, appId])
}

model GroupAppAccess {
  id        String @id @default(cuid())
  groupId   String
  group     group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  appId     String
  app       app    @relation(fields: [appId], references: [id])
  expiresAt DateTime?
  createdAt DateTime @default(now())
  appSessions userAppSession[]

  @@unique([groupId, appId])
}

model userAppSession {
  id              String        @id @default(cuid())
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  userAppAccessId String?
  userAppAccess   userAppAccess? @relation(fields: [userAppAccessId], references: [id], onDelete: Cascade)
  groupAppAccessId String?
  groupAppAccess  GroupAppAccess? @relation(fields: [groupAppAccessId], references: [id], onDelete: Cascade)
  sessionId       String
  session         session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([userAppAccessId, sessionId])
}

model domain {
  id          String   @id @unique @default(uuid())
  name        String   @unique
  createdAt   DateTime @default(now())
  accessedAt  DateTime @default(now())
  creatorId   String?
  creator     User?    @relation(fields: [creatorId], references: [id], name: "DomainsCreator")
  verified    Boolean  @default(false)
  tenantId    String
  tenant      tenant?  @relation(fields: [tenantId], references: [id], name: "tenantDomains")
  hasMXRecord Boolean  @default(false)
  domainUsers User[]   @relation(name: "domainUsers")
  groups      group[]  @relation(name: "domainGroups")
}

model DeviceGroup {
  id       String @id @default(cuid())
  deviceId String
  groupId  String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  group    group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([deviceId, groupId])
}

enum DeviceHardwareType {
  LAPTOP
  PHONE
  TABLET
  SERVER
  OTHER
}

enum DeviceSoftwareType {
  THETAOS
  ANDROID
  OTHER
}

model Device {
  id             String             @id @default(cuid())
  name           String
  displayName    String
  os             String
  osVersion      String
  hardwareType   DeviceHardwareType @default(OTHER)
  softwareType   DeviceSoftwareType @default(OTHER)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  assignedTo     String?
  groups         DeviceGroup[]
  user           User?              @relation(fields: [assignedTo], references: [id])
  mdmServerId    String?
  mdmServer      MdmServer?         @relation(fields: [mdmServerId], references: [id])
  extraInfo      Json?
  lastCheckIn    DateTime?
  token          String             @unique @default(cuid())
  tenantId       String
  tenant         tenant             @relation(fields: [tenantId], references: [id])
  isSelfEnrolled Boolean            @default(false)
  enrolledById   String
  enrolledBy     User?              @relation(fields: [enrolledById], references: [id], name: "EnrolledDevices")
  enrolledAt     DateTime           @default(now())
  serialNumber   String?
  locationId     String?
  location       location?          @relation(fields: [locationId], references: [id])
  tags           String[]

  @@unique([tenantId, serialNumber])
}

model MdmServer {
  id              String   @id @default(cuid())
  name            String
  url             String
  tenantId        String
  tenant          tenant   @relation(fields: [tenantId], references: [id])
  devices         Device[]
  enrollmentToken String
  isDefault       Boolean  @default(false)

  @@unique([tenantId, isDefault])
}
